# Runtime artifacts — генерируются агентами, не коммитятся
agent-runtime/shared/*
agent-runtime/messages/*
agent-runtime/state/*
agent-runtime/outputs/frontend/*
agent-runtime/outputs/tests/backend/*
agent-runtime/outputs/tests/frontend/*
agent-runtime/outputs/final-summary.md

# Сохраняем структуру директорий и шаблоны
!agent-runtime/shared/.gitkeep
!agent-runtime/shared/brief.template.md
!agent-runtime/messages/.gitkeep
!agent-runtime/messages/message-template.md
!agent-runtime/state/.gitkeep
!agent-runtime/outputs/frontend/.gitkeep
!agent-runtime/outputs/tests/backend/.gitkeep
!agent-runtime/outputs/tests/frontend/.gitkeep

# Секреты и данные
*.json
!package.json
!package-lock.json
!tsconfig*.json
!vercel.json
*.csv

# Конфиг с локальными разрешениями (содержит персональные токены/пути)
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node
node_modules/
dist/
.env
.env.local
